generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String          @id @default(cuid())
  walletAddress      String          @unique
  role               UserRole        @default(USER)
  lastLoginAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  profileCompleted   Boolean         @default(false)
  upiId              String?
  smartWalletAddress String?         @unique
  solanaAddress      String?         @unique
  bankDetails        BankDetails?
  orders             Order[]
  qrTransactions     QRTransaction[]

  @@map("users")
}

model BankDetails {
  id                String   @id @default(cuid())
  userId            String   @unique
  accountNumber     String
  ifscCode          String
  branchName        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  accountHolderName String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_details")
}

model Order {
  id                    String      @id @default(cuid())
  blockchainOrderId     String?
  userId                String
  amount                Decimal
  orderType             OrderType
  status                OrderStatus @default(PENDING)
  paymentProof          String?
  adminUpiId            String?
  adminBankDetails      String?
  adminNotes            String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  buyRate               Decimal?
  sellRate              Decimal?
  usdtAmount            Decimal?
  isCompletedOnChain    Boolean     @default(false)
  isVerifiedOnChain     Boolean     @default(false)
  transactionHash       String?
  customAmount          Decimal?
  userConfirmedAt       DateTime?
  userConfirmedReceived Boolean     @default(false)
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model Rate {
  id        String       @id @default(cuid())
  type      RateType
  currency  CurrencyType @default(UPI)
  buyRate   Decimal
  sellRate  Decimal
  updatedBy String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([type, currency])
  @@map("rates")
}

model FeatureFlag {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("feature_flags")
}

model QRTransaction {
  id               String              @id @default(cuid())
  userId           String
  amountINR        Decimal
  amountUSDT       Decimal
  fee              Decimal             @default(0)
  transactionHash  String?             @unique
  status           QRTransactionStatus @default(PENDING)
  qrCodeData       String?
  adminCompletedAt DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  sellRate         Decimal?
  userOpHash       String?             @unique
  scannedUpiId     String?
  adminNotes       String?
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("qr_transactions")
}

enum UserRole {
  USER
  ADMIN
}

enum OrderType {
  BUY_UPI
  BUY_CDM
  SELL
  SELL_CDM
}

enum OrderStatus {
  PENDING
  ADMIN_APPROVED
  PAYMENT_SUBMITTED
  COMPLETED
  CANCELLED
  ADMIN_SENT_PAYMENT_INFO
  PAYMENT_VERIFIED
  USDT_TRANSFERRED
  USDT_RECEIVED_BY_ADMIN
  PENDING_ADMIN_PAYMENT
}

enum RateType {
  CURRENT
}

enum CurrencyType {
  UPI
  CDM
}

enum QRTransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
  APPROVED
}
